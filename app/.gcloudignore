# Cloud Run upload filter (overrides .gitignore, so dist/ uploads).
# Keep runtime needs: main.py, parcel_app.py, parcel/ modules, dist/ (incl parcel.html),
# data/*.json + data/*.geojson (recommend.py reads records.json + scores). Drop build-only + heavy.
.git/
.gitignore
__pycache__/
*.pyc
_scratch/
_*.json
_*.txt
data/raw/
data/yt/
data/transcripts/
data/*.png
data/*.dxf
*.gguf
counties_all.json
get_geo.py
get_transmission.py
get_fiber.py
get_water.py
get_substations.py
pipeline.py
build_site.py
sentiment_youtube.py
